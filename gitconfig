[user]
	email = kevin.gray.chan@gmail.com
	name = Kevin Chan
[core]
	excludesfile = ~/.gitignore_global
[difftool]
    prompt = false
[commit]
	template = ~/.git_commit_template.txt
[pull]
	ff = only
[init]
	defaultBranch = main

# From https://blog.gitbutler.com/how-git-core-devs-configure-git/
# [column]
# 	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[push]
	default = simple
	autoSetupRemote = true
	followTags = true
[fetch]
	prune = true
	pruneTags = true
	all = true
# Extra
[help]
	autocorrect = prompt
[commit]
	verbose = true
[rerere]
	enabled = true
	autoupdate = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
